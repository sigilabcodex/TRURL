{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trurl.local/schema/trurl-project.schema.json",
  "title": "TRURL Project Manifest",
  "description": "Schema for .trurl/project.json. Additional properties are allowed to keep the v0 manifest forward-compatible while core fields stabilize.",
  "type": "object",
  "required": [
    "schema",
    "title",
    "defaultDocument",
    "documents"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trurl-project/v0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "defaultDocument": {
      "type": "string",
      "minLength": 1
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "manuscriptPath",
          "storyBiblePath",
          "notesPath",
          "revisionPath",
          "renderPresets"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "manuscriptPath": {
            "type": "string",
            "minLength": 1
          },
          "storyBiblePath": {
            "type": "string",
            "minLength": 1
          },
          "notesPath": {
            "type": "string",
            "minLength": 1
          },
          "revisionPath": {
            "type": "string",
            "minLength": 1
          },
          "renderPresets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
