{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trurl.local/schema/document-schema.json",
  "title": "TRURL Frontmatter Schema (Draft)",
  "description": "Minimal evolving schema for manuscript and story-bible frontmatter.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/manuscript" },
    { "$ref": "#/$defs/character" },
    { "$ref": "#/$defs/location" },
    { "$ref": "#/$defs/timeline" }
  ],
  "$defs": {
    "id_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "manuscript": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^ms\\..+" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["chapter", "interlude", "appendix", "fragment"] },
        "order": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "enum": ["draft", "revised", "locked", "deprecated"] },
        "character_ids": { "$ref": "#/$defs/id_list" },
        "location_ids": { "$ref": "#/$defs/id_list" },
        "timeline_ids": { "$ref": "#/$defs/id_list" },
        "source_text": { "type": "string" },
        "source_url": { "type": "string" }
      },
      "required": ["id", "title", "type", "order", "status", "character_ids", "location_ids", "timeline_ids"],
      "additionalProperties": true
    },
    "character": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^char\\..+" },
        "type": { "const": "character" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "canon": { "type": "string", "enum": ["canonical", "provisional"] },
        "aliases": { "$ref": "#/$defs/id_list" },
        "first_appearance": { "type": "string" }
      },
      "required": ["id", "type", "name", "status", "canon"],
      "additionalProperties": true
    },
    "location": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^loc\\..+" },
        "type": { "const": "location" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "canon": { "type": "string", "enum": ["canonical", "provisional"] },
        "aliases": { "$ref": "#/$defs/id_list" },
        "region": { "type": "string" }
      },
      "required": ["id", "type", "name", "status", "canon"],
      "additionalProperties": true
    },
    "timeline": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^time\\..+" },
        "type": { "const": "timeline" },
        "label": { "type": "string" },
        "sequence": { "type": "integer", "minimum": 1 },
        "status": { "type": "string" },
        "canon": { "type": "string", "enum": ["canonical", "provisional"] },
        "character_ids": { "$ref": "#/$defs/id_list" },
        "location_ids": { "$ref": "#/$defs/id_list" },
        "source_manuscript": { "type": "string" }
      },
      "required": ["id", "type", "label", "sequence", "status", "canon"],
      "additionalProperties": true
    }
  }
}
